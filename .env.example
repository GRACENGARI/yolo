# HAWKEYE CV-Engine Configuration
# Copy this file to .env and configure for your deployment

# ============================================
# HARDWARE & PERFORMANCE
# ============================================
DEVICE=cpu                          # Options: cpu, cuda, gpu
DETECTION_THRESHOLD=0.4             # YOLO confidence threshold (0.0-1.0)
VRAM_LIMIT_MB=4096                 # Maximum VRAM usage before triggering warnings
ENABLE_FP16=true                   # Use half-precision on GPU (faster, less VRAM)

# ============================================
# VIDEO SOURCE
# ============================================
VIDEO_SOURCE=people.mp4            # Options: file path, rtsp://url, http://url, 0 (webcam)
RTSP_RECONNECT_ATTEMPTS=5          # Number of reconnection attempts for RTSP streams
RTSP_RECONNECT_DELAY=3             # Seconds between reconnection attempts

# ============================================
# BACKEND COMMUNICATION
# ============================================
BACKEND_URL=http://localhost:8000/api/v1/
API_KEY=                           # Optional: API key for authentication
ENABLE_MTLS=false                  # Enable mutual TLS authentication
MTLS_CERT_PATH=./certs/client.crt
MTLS_KEY_PATH=./certs/client.key
MTLS_CA_PATH=./certs/ca.crt

# ============================================
# CAMERA CONFIGURATION
# ============================================
CAMERA_ID=CAM-LIVE-SIM
CAMERA_LOCATION=Grid Sector Alpha-01
CAMERA_LAT=-1.285
CAMERA_LNG=36.821

# ============================================
# AI MODELS
# ============================================
YOLO_MODEL=yolov8n.pt              # Detection model
ARCFACE_MODEL=buffalo_s            # Face recognition model (buffalo_s for edge)
REID_MODEL=osnet_x1_0              # ReID model for tracking
ENHANCEMENT_MODEL=gfpgan           # Options: gfpgan, codeformer, basic

# ============================================
# FORENSIC ENHANCEMENT
# ============================================
ENABLE_ENHANCEMENT=true            # Enable forensic image enhancement
ENHANCEMENT_THRESHOLD=0.4          # Trigger enhancement if confidence < this
MIN_FACE_SIZE=20                   # Minimum face size (px) to attempt enhancement
SAVE_FORENSIC_AUDIT=true          # Save raw + enhanced comparison images
FORENSIC_AUDIT_DIR=./forensic_audit

# ============================================
# TRACKING & REPORTING
# ============================================
REPORT_INTERVAL=30                 # Seconds between re-reports for same track
MAX_COSINE_DISTANCE=0.4           # DeepSORT matching threshold
ENABLE_REID=true                   # Use advanced ReID model (vs SimpleEncoder)

# ============================================
# FLASK SERVER
# ============================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=false

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO                     # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=cv_out.log
